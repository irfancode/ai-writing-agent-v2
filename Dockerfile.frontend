FROM node:20-slim

WORKDIR /app

# Copy package files
COPY frontend/package*.json ./

# Install dependencies
RUN npm install

# Copy the rest of the frontend code
COPY frontend/ .

# Expose Vite's default port
EXPOSE 5173

# Run Vite dev server, allowing external host connections
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
